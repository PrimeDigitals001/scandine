# ScanDine environment — copy to .env.local and fill in. NEVER commit .env.local.
# Hosted Supabase values come from: Supabase Dashboard → Project Settings → API.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only — NEVER prefix with NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Super Admin portal (separate from Supabase Auth; step 3) ---
SUPER_ADMIN_EMAIL=
# bcrypt hash, NOT the plaintext password. IMPORTANT: escape every `$` as `\$`
# (Next's env loader expands unescaped `$` and will corrupt the hash), e.g.
#   SUPER_ADMIN_PASSWORD_HASH=\$2b\$10\$abc...
SUPER_ADMIN_PASSWORD_HASH=
SUPER_ADMIN_SESSION_SECRET=         # long random string (e.g. `openssl rand -hex 32`)

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
